-- Realtime Tanks Demo — Defold client
-- 2D top-down view using Colyseus Defold SDK

local Colyseus = require "colyseus.sdk"

local SCALE = 16
local MAP_SIZE = 48 * SCALE
local ZOOM = 1.5

local TEAM_COLORS = {
	[0] = vmath.vector4(1, 0.27, 0.27, 1),
	[1] = vmath.vector4(0.27, 0.53, 1, 1),
	[2] = vmath.vector4(0.27, 1, 0.27, 1),
	[3] = vmath.vector4(1, 1, 0.27, 1),
}
local TEAM_NAMES = { [0] = "Red", [1] = "Blue", [2] = "Green", [3] = "Yellow" }

local TEAM_BODY_SPRITES = {
	[0] = hash("tank_body_red"),
	[1] = hash("tank_body_blue"),
	[2] = hash("tank_body_green"),
	[3] = hash("tank_body_yellow"),
}
local TEAM_BARREL_SPRITES = {
	[0] = hash("barrel_red"),
	[1] = hash("barrel_blue"),
	[2] = hash("barrel_green"),
	[3] = hash("barrel_yellow"),
}

local PICKABLE_SPRITES = {
	damage = hash("pickup_damage"),
	repair = hash("pickup_repair"),
	shield = hash("pickup_shield"),
}

local LEVEL = {
	{13.5, 2, 1, 4}, {13.5, 12, 1, 2}, {12.5, 13.5, 3, 1}, {2, 13.5, 4, 1},
	{11.5, 15, 1, 2}, {11.5, 23.5, 1, 5},
	{10, 26.5, 4, 1}, {6, 26.5, 4, 1},
	{2, 34.5, 4, 1}, {12.5, 34.5, 3, 1}, {13.5, 36, 1, 2}, {15, 36.5, 2, 1},
	{13.5, 46, 1, 4},
	{23.5, 36.5, 5, 1}, {26.5, 38, 1, 4}, {26.5, 42, 1, 4},
	{34.5, 46, 1, 4}, {34.5, 36, 1, 2}, {35.5, 34.5, 3, 1}, {36.5, 33, 1, 2},
	{46, 34.5, 4, 1},
	{36.5, 24.5, 1, 5}, {38, 21.5, 4, 1}, {42, 21.5, 4, 1},
	{46, 13.5, 4, 1}, {35.5, 13.5, 3, 1}, {34.5, 12, 1, 2}, {33, 11.5, 2, 1},
	{34.5, 2, 1, 4},
	{24.5, 11.5, 5, 1}, {21.5, 10, 1, 4}, {21.5, 6, 1, 4},
	{18.5, 22, 1, 6}, {19, 18.5, 2, 1}, {26, 18.5, 6, 1}, {29.5, 19, 1, 2},
	{29.5, 26, 1, 6}, {29, 29.5, 2, 1}, {22, 29.5, 6, 1}, {18.5, 29, 1, 2},
}

-- ── Effects ──

local function spawn_explosion(self, x, y)
	-- Fireball (circle: go_scale * 10 * 32 = visual pixels)
	local fb = factory.create("#pickable_factory", vmath.vector3(x, y, 0.8))
	sprite.play_flipbook(msg.url(nil, fb, "sprite"), hash("circle"))
	sprite.set_constant(msg.url(nil, fb, "sprite"), "tint", vmath.vector4(1, 0.6, 0.1, 0.9))
	go.set_scale(vmath.vector3(0.03, 0.03, 1), fb)
	go.animate(fb, "scale", go.PLAYBACK_ONCE_FORWARD, vmath.vector3(0.25, 0.25, 1), go.EASING_OUTQUAD, 0.4, 0, function()
		go.delete(fb)
	end)

	-- Ring
	local ring = factory.create("#pickable_factory", vmath.vector3(x, y, 0.7))
	sprite.play_flipbook(msg.url(nil, ring, "sprite"), hash("circle"))
	sprite.set_constant(msg.url(nil, ring, "sprite"), "tint", vmath.vector4(1, 0.3, 0, 0.6))
	go.set_scale(vmath.vector3(0.06, 0.06, 1), ring)
	go.animate(ring, "scale", go.PLAYBACK_ONCE_FORWARD, vmath.vector3(0.38, 0.38, 1), go.EASING_OUTQUAD, 0.5, 0, function()
		go.delete(ring)
	end)
end

local function play_shield_break(self, tank)
	-- Flash shield white and expand, then fade
	sprite.set_constant(msg.url(nil, tank.shield_id, "sprite"), "tint", vmath.vector4(1, 1, 1, 0.5))
	go.animate(tank.shield_id, "scale", go.PLAYBACK_ONCE_FORWARD, vmath.vector3(2, 2, 1), go.EASING_OUTQUAD, 0.3, 0, function()
		go.set_scale(vmath.vector3(1, 1, 1), tank.shield_id)
		sprite.set_constant(msg.url(nil, tank.shield_id, "sprite"), "tint", vmath.vector4(0.27, 0.8, 1, 0))
	end)
end

-- ── Helpers ──

local function build_level(self)
	for _, block in ipairs(LEVEL) do
		local bx, by, bw, bh = block[1], block[2], block[3], block[4]
		local id = factory.create("#block_factory", vmath.vector3(bx * SCALE, by * SCALE, 0))
		go.set_scale(vmath.vector3(bw * SCALE, bh * SCALE, 1), id)
		sprite.set_constant(msg.url(nil, id, "sprite"), "tint", vmath.vector4(0.13, 0.4, 0.67, 0.85))
		table.insert(self.blocks, id)
	end

	local thickness = 1.5
	local wall_color = vmath.vector4(0.1, 0.27, 0.53, 0.9)
	local walls = {
		{ 24, -thickness / 2, 48 + thickness * 2, thickness },
		{ 24, 48 + thickness / 2, 48 + thickness * 2, thickness },
		{ -thickness / 2, 24, thickness, 48 + thickness * 2 },
		{ 48 + thickness / 2, 24, thickness, 48 + thickness * 2 },
	}
	for _, w in ipairs(walls) do
		local id = factory.create("#block_factory", vmath.vector3(w[1] * SCALE, w[2] * SCALE, 0))
		go.set_scale(vmath.vector3(w[3] * SCALE, w[4] * SCALE, 1), id)
		sprite.set_constant(msg.url(nil, id, "sprite"), "tint", wall_color)
		table.insert(self.blocks, id)
	end
end

local function update_leaderboard(self)
	local sorted = {}
	for id, score in pairs(self.team_scores) do
		table.insert(sorted, { id = id, score = score })
	end
	table.sort(sorted, function(a, b) return a.score > b.score end)
	local lines = {}
	for _, t in ipairs(sorted) do
		table.insert(lines, (TEAM_NAMES[t.id] or "?") .. ": " .. t.score)
	end
	msg.post("hud#gui", "update_leaderboard", { text = table.concat(lines, "\n") })
end

local function show_announcement(self, text, duration)
	msg.post("hud#gui", "show_announcement", { text = text, duration = duration or 3.0 })
end

local function show_winner(self, winner_team_id)
	self.winner_active = true
	local my_tank = self.tanks[self.my_session_id]
	local is_winner = my_tank and my_tank.team == winner_team_id
	local text = is_winner and "VICTORY" or "DEFEAT"
	local team_name = TEAM_NAMES[winner_team_id] or "?"
	show_announcement(self, text .. "\n" .. team_name .. " Team Wins", 3.0)
	timer.delay(3.0, false, function() self.winner_active = false end)
end

local function bind_room_events(self, room)
	local cb = Colyseus.callbacks(room)

	-- Tanks
	cb:on_add("tanks", function(tank, key)
		local sx, sy = tank.x * SCALE, tank.y * SCALE
		local body_id = factory.create("#tank_factory", vmath.vector3(sx, sy, 0))
		local turret_id = factory.create("#turret_factory", vmath.vector3(sx, sy, 0.5))
		local shield_id = factory.create("#shield_factory", vmath.vector3(sx, sy, 0.9))
		-- Set team-colored sprites
		local body_sprite = TEAM_BODY_SPRITES[tank.team] or TEAM_BODY_SPRITES[0]
		local barrel_sprite = TEAM_BARREL_SPRITES[tank.team] or TEAM_BARREL_SPRITES[0]
		sprite.play_flipbook(msg.url(nil, body_id, "body"), body_sprite)
		sprite.play_flipbook(msg.url(nil, turret_id, "sprite"), barrel_sprite)
		sprite.set_constant(msg.url(nil, shield_id, "sprite"), "tint",
			vmath.vector4(0.27, 0.8, 1, 0))

		self.tanks[key] = {
			body_id = body_id, turret_id = turret_id, shield_id = shield_id,
			target_x = sx, target_y = sy,
			turret_angle = 0, target_turret_angle = 0,
			body_angle = 0, target_body_angle = 0,
			dead = tank.dead, team = tank.team, shield = 0, hp = tank.hp or 10,
		}

		-- Per-tank GUI bars
		msg.post("hud#gui", "tank_bar_add", { key = key })
		msg.post("hud#gui", "tank_bar_hp", { key = key, hp = tank.hp })

		cb:listen(tank, "x", function(val)
			local t = self.tanks[key]
			if t then t.target_x = val * SCALE end
		end)
		cb:listen(tank, "y", function(val)
			local t = self.tanks[key]
			if t then t.target_y = val * SCALE end
		end)
		cb:listen(tank, "angle", function(val)
			-- Skip server angle for current player; client trusts its own turret aim
			if key == self.my_session_id then return end
			local t = self.tanks[key]
			if t then t.target_turret_angle = -val * (math.pi / 180) end
		end)
		cb:listen(tank, "dead", function(val)
			local t = self.tanks[key]
			if not t then return end
			local was_alive = not t.dead
			t.dead = val
			-- Only explode on combat death (HP reached 0), not round reset
			if val and was_alive and t.hp <= 0 then
				local pos = go.get_position(t.body_id)
				spawn_explosion(self, pos.x, pos.y)
			end
			if key == self.my_session_id and val and not self.winner_active then
				show_announcement(self, "DESTROYED\nRespawning...", 2.0)
			end
		end)
		cb:listen(tank, "hp", function(val)
			local t = self.tanks[key]
			if t then t.hp = val end
			msg.post("hud#gui", "tank_bar_hp", { key = key, hp = val })
			if key == self.my_session_id then
				msg.post("hud#gui", "update_hp", { hp = val })
			end
		end)
		cb:listen(tank, "shield", function(val)
			local t = self.tanks[key]
			if t then
				local had_shield = t.shield > 0
				t.shield = val
				if had_shield and val <= 0 then
					play_shield_break(self, t)
				end
			end
			msg.post("hud#gui", "tank_bar_shield", { key = key, shield = val })
			if key == self.my_session_id then
				msg.post("hud#gui", "update_shield", { shield = val })
			end
		end)
		cb:listen(tank, "score", function(val)
			update_leaderboard(self)
		end)
	end)

	cb:on_remove("tanks", function(tank, key)
		local t = self.tanks[key]
		if t then
			go.delete(t.body_id)
			go.delete(t.turret_id)
			go.delete(t.shield_id)
			self.tanks[key] = nil
		end
		msg.post("hud#gui", "tank_bar_remove", { key = key })
	end)

	-- Bullets
	cb:on_add("bullets", function(bullet, key)
		local sx, sy = bullet.x * SCALE, bullet.y * SCALE
		local id = factory.create("#bullet_factory", vmath.vector3(sx, sy, 0.2))
		if bullet.special then
			sprite.play_flipbook(msg.url(nil, id, "sprite"), hash("bullet_special"))
		end
		self.bullets[key] = { id = id, target_x = sx, target_y = sy }

		cb:listen(bullet, "x", function(val)
			local b = self.bullets[key]
			if b then b.target_x = val * SCALE end
		end)
		cb:listen(bullet, "y", function(val)
			local b = self.bullets[key]
			if b then b.target_y = val * SCALE end
		end)
	end)

	cb:on_remove("bullets", function(bullet, key)
		local b = self.bullets[key]
		if b then
			go.delete(b.id)
			self.bullets[key] = nil
		end
	end)

	-- Pickables
	cb:on_add("pickables", function(pick, key)
		local sx, sy = pick.x * SCALE, pick.y * SCALE
		local id = factory.create("#pickable_factory", vmath.vector3(sx, sy, 0.1))
		local pickup_sprite = PICKABLE_SPRITES[pick.type]
		if pickup_sprite then
			sprite.play_flipbook(msg.url(nil, id, "sprite"), pickup_sprite)
		end
		self.pickables[key] = { id = id, type = pick.type }
	end)

	cb:on_remove("pickables", function(pick, key)
		local p = self.pickables[key]
		if p then
			go.delete(p.id)
			self.pickables[key] = nil
		end
	end)

	-- Teams
	cb:on_add("teams", function(team, idx)
		local team_id = idx - 1
		self.team_scores[team_id] = team.score or 0
		update_leaderboard(self)
		cb:listen(team, "score", function(val)
			self.team_scores[team_id] = val
			update_leaderboard(self)
		end)
	end)

	-- Winner
	cb:listen("winnerTeam", function(val, prev)
		if type(val) == "number" and val >= 0 and val ~= prev then
			show_winner(self, val)
		end
	end)
end

local function send_input(self)
	local raw_x, raw_y = 0, 0
	if self.keys["up"] then raw_y = raw_y - 1 end
	if self.keys["down"] then raw_y = raw_y + 1 end
	if self.keys["left"] then raw_x = raw_x - 1 end
	if self.keys["right"] then raw_x = raw_x + 1 end

	local dir_x = raw_x
	local dir_y = -raw_y

	if dir_x ~= self.last_dir_x or dir_y ~= self.last_dir_y then
		self.room:send("move", { x = dir_x, y = dir_y })
		self.last_dir_x = dir_x
		self.last_dir_y = dir_y
	end

	local my_tank = self.tanks[self.my_session_id]
	if my_tank then
		local tank_pos = go.get_position(my_tank.body_id)
		local cam_pos = go.get_position("camera")
		local sw = tonumber(sys.get_config("display.width"))
		local sh = tonumber(sys.get_config("display.height"))
		local world_x = (self.mouse_x - sw / 2) / ZOOM + cam_pos.x
		local world_y = (self.mouse_y - sh / 2) / ZOOM + cam_pos.y

		local dx = world_x - tank_pos.x
		local dy = world_y - tank_pos.y
		local aim_angle = math.atan2(dx, dy) * (180 / math.pi)
		aim_angle = ((aim_angle % 360) + 360) % 360

		-- Apply turret angle locally for instant feedback
		my_tank.target_turret_angle = -aim_angle * (math.pi / 180)

		local now = socket.gettime() * 1000
		if math.abs(aim_angle - self.last_angle) > 1 and (now - self.last_target_send_time) >= 100 then
			self.room:send("target", aim_angle)
			self.last_angle = aim_angle
			self.last_target_send_time = now
		end
	end
end

-- ── Defold lifecycle ──

function init(self)
	msg.post(".", "acquire_input_focus")

	self.room = nil
	self.my_session_id = nil
	self.tanks = {}
	self.bullets = {}
	self.pickables = {}
	self.blocks = {}
	self.keys = {}
	self.mouse_x = 0
	self.mouse_y = 0
	self.mouse_down = false
	self.last_dir_x = -999
	self.last_dir_y = -999
	self.last_angle = -999
	self.last_target_send_time = 0
	self.team_scores = {}
	self.winner_active = false

	build_level(self)

	local server_url = "ws://localhost:2567"
	if html5 then
		local param = html5.run("new URLSearchParams(window.location.search).get('server') || ''")
		if param ~= "" then
			server_url = param
		elseif html5.run("window.location.hostname") ~= "localhost" and html5.run("window.location.hostname") ~= "127.0.0.1" then
			server_url = "wss://tanks-demo.colyseus.dev"
		end
	end
	local client = Colyseus.Client(server_url)
	client:join_or_create("battle", function(err, room)
		if err then
			print("Connection error: " .. tostring(err))
			return
		end
		self.room = room
		self.my_session_id = room.session_id
		print("Joined room: " .. room.room_id .. " as " .. room.session_id)
		bind_room_events(self, room)
	end)
end

function update(self, dt)
	if not self.room then return end

	send_input(self)

	for key, tank in pairs(self.tanks) do
		local pos = go.get_position(tank.body_id)
		local new_x = pos.x + (tank.target_x - pos.x) * 0.2
		local new_y = pos.y + (tank.target_y - pos.y) * 0.2

		-- Body position
		go.set_position(vmath.vector3(new_x, new_y, 0), tank.body_id)

		-- Body rotation toward movement (smoothed with angle unwrapping)
		local dx = tank.target_x - pos.x
		local dy = tank.target_y - pos.y
		if math.abs(dx) > 0.5 or math.abs(dy) > 0.5 then
			tank.target_body_angle = math.atan2(dy, dx) - math.pi / 2
		end
		local body_diff = tank.target_body_angle - tank.body_angle
		while body_diff > math.pi do body_diff = body_diff - math.pi * 2 end
		while body_diff < -math.pi do body_diff = body_diff + math.pi * 2 end
		tank.body_angle = tank.body_angle + body_diff * 0.15
		go.set_rotation(vmath.quat_rotation_z(tank.body_angle), tank.body_id)

		-- Turret follows body position, independent rotation (smoothed with angle unwrapping)
		go.set_position(vmath.vector3(new_x, new_y, 0.5), tank.turret_id)
		local turret_diff = tank.target_turret_angle - tank.turret_angle
		while turret_diff > math.pi do turret_diff = turret_diff - math.pi * 2 end
		while turret_diff < -math.pi do turret_diff = turret_diff + math.pi * 2 end
		tank.turret_angle = tank.turret_angle + turret_diff * 0.25
		go.set_rotation(vmath.quat_rotation_z(tank.turret_angle), tank.turret_id)

		-- Shield follows body
		go.set_position(vmath.vector3(new_x, new_y, 0.9), tank.shield_id)
		if tank.shield > 0 then
			local pulse = 0.2 + math.sin(socket.gettime() * 4) * 0.1
			sprite.set_constant(msg.url(nil, tank.shield_id, "sprite"), "tint",
				vmath.vector4(0.27, 0.8, 1, pulse))
		end

		-- Dead blink
		local visible = true
		if tank.dead then
			visible = (math.floor(socket.gettime() * 4) % 2 == 0)
		end
		msg.post(msg.url(nil, tank.body_id, "body"), visible and "enable" or "disable")
		msg.post(msg.url(nil, tank.turret_id, "sprite"), visible and "enable" or "disable")
	end

	-- Bullets
	for key, bullet in pairs(self.bullets) do
		local pos = go.get_position(bullet.id)
		local dx = bullet.target_x - pos.x
		local dy = bullet.target_y - pos.y
		-- Rotate bullet to face travel direction
		if math.abs(dx) > 0.1 or math.abs(dy) > 0.1 then
			local angle = math.atan2(dy, dx) - math.pi / 2
			go.set_rotation(vmath.quat_rotation_z(angle), bullet.id)
		end
		local new_x = pos.x + dx * 0.4
		local new_y = pos.y + dy * 0.4
		go.set_position(vmath.vector3(new_x, new_y, 0.2), bullet.id)
	end

	-- Pickable pulse and spin (48x48 sprites with internal scale 10 → go_scale 0.05 ≈ 24px)
	local t = socket.gettime()
	for key, pick in pairs(self.pickables) do
		local s = 0.05 * (1.0 + math.sin(t * 3) * 0.15)
		go.set_scale(vmath.vector3(s, s, 1), pick.id)
		if pick.type == "damage" then
			go.set_rotation(vmath.quat_rotation_z(t * 2), pick.id)
		end
	end

	-- Update per-tank bar positions (world → screen)
	local cam_pos = go.get_position("camera")
	local sw = tonumber(sys.get_config("display.width"))
	local sh = tonumber(sys.get_config("display.height"))
	for key, tank in pairs(self.tanks) do
		local pos = go.get_position(tank.body_id)
		-- World to screen: offset from camera center, scaled by zoom
		local screen_x = (pos.x - cam_pos.x) * ZOOM + sw / 2
		local screen_y = (pos.y - cam_pos.y) * ZOOM + sh / 2 + 20 * ZOOM -- offset above tank
		local visible = not tank.dead or (math.floor(socket.gettime() * 4) % 2 == 0)
		msg.post("hud#gui", "tank_bar_pos", { key = key, x = screen_x, y = screen_y, visible = visible })
	end

	-- Camera follow with mouse look-ahead
	local my_tank = self.tanks[self.my_session_id]
	if my_tank then
		local tank_pos = go.get_position(my_tank.body_id)
		local sw = tonumber(sys.get_config("display.width"))
		local sh = tonumber(sys.get_config("display.height"))
		local nx = (self.mouse_x / sw) * 2 - 1
		local ny = (self.mouse_y / sh) * 2 - 1
		local look_ahead = 30
		local cam_pos = go.get_position("camera")
		local new_x = cam_pos.x + (tank_pos.x + nx * look_ahead - cam_pos.x) * 0.08
		local new_y = cam_pos.y + (tank_pos.y + ny * look_ahead - cam_pos.y) * 0.08
		go.set_position(vmath.vector3(new_x, new_y, 0), "camera")
	end
end

function on_input(self, action_id, action)
	if action_id == hash("up") then
		self.keys["up"] = not action.released
	elseif action_id == hash("down") then
		self.keys["down"] = not action.released
	elseif action_id == hash("left") then
		self.keys["left"] = not action.released
	elseif action_id == hash("right") then
		self.keys["right"] = not action.released
	elseif action_id == hash("shoot") then
		if action.pressed then
			self.mouse_down = true
			if self.room then self.room:send("shoot", true) end
		elseif action.released then
			self.mouse_down = false
			if self.room then self.room:send("shoot", false) end
		end
	end

	if not action_id then
		self.mouse_x = action.x
		self.mouse_y = action.y
	end

	return false
end

function final(self)
	if self.room then
		self.room:leave()
	end
end
